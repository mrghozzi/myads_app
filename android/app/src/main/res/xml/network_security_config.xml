<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration
  
  Production: Cleartext traffic is blocked by default (HTTPS enforced).
  Development: Only localhost and private network IPs are allowed cleartext
  for local testing with XAMPP/Docker/emulators.
  
  To add more development IPs, add them inside the domain-config block.
-->
<network-security-config>
    <!-- Allow cleartext only for local development servers -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Add your local dev IP here if needed, e.g.: -->
        <!-- <domain includeSubdomains="true">192.168.1.163</domain> -->
    </domain-config>

    <!-- Allow cleartext for development to fix ExoPlayer blocking local IP media -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
